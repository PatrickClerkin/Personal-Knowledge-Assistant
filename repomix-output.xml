</head>
<body>
<div class="container">
  <h1>🧠 Quiz Mode</h1>
  <p class="subtitle">Test your knowledge with questions generated from your documents</p>

  <div class="input-row">
    <input type="text" id="topicInput"
           placeholder="What topic do you want to be quizzed on? e.g. neural networks…"/>
    <button id="generateBtn" onclick="generateQuiz()">Generate Quiz</button>
  </div>

  <div id="status"></div>

  <div id="scoreBar" class="score-bar" style="display:none">
    <div>
      <div class="score-label">Score</div>
      <div class="score-value" id="scoreDisplay">0 / 0</div>
    </div>
    <div class="progress-wrap">
      <div class="progress-fill" id="scoreFill" style="width:0%"></div>
    </div>
    <div>
      <div class="score-label">Answered</div>
      <div class="score-value" id="answeredDisplay">0</div>
    </div>
  </div>

  <div id="quizOutput"></div>

  <div class="results-panel" id="resultsPanel">
    <div class="results-title">🎉 Quiz Complete!</div>
    <div class="results-score" id="finalScore">-</div>
    <div class="results-sub" id="finalSub"></div>
  </div>
</div>

<script>
  let quizData = null;
  let mcqAnswers = {};   // index → selected letter
  let mcqCorrect = {};   // index → bool
  let saRevealed = {};   // index → bool
  let totalMCQ = 0;
  let correctMCQ = 0;
  let answeredMCQ = 0;

  function setStatus(msg, type) {
    const el = document.getElementById("status");
    el.textContent = msg;
    el.className = type;
  }

  function clearStatus() {
    const el = document.getElementById("status");
    el.className = "";
    el.textContent = "";
  }

  async function generateQuiz() {
    const topic = document.getElementById("topicInput").value.trim();
    if (!topic) return;

    const btn = document.getElementById("generateBtn");
    btn.disabled = true;
    btn.textContent = "Generating…";
    setStatus(`Generating quiz on "${topic}" — this may take 30–60 seconds…`, "info");

    document.getElementById("quizOutput").innerHTML = "";
    document.getElementById("scoreBar").style.display = "none";
    document.getElementById("resultsPanel").classList.remove("show");

    mcqAnswers = {}; mcqCorrect = {}; saRevealed = {};
    totalMCQ = 0; correctMCQ = 0; answeredMCQ = 0;

    try {
      const res = await fetch("/api/quiz/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ topic }),
      });
      const data = await res.json();

      if (!res.ok || data.error) {
        setStatus(`Error: ${data.error || "Unknown error"}`, "error");
        return;
      }

      if (data.total_questions === 0) {
        setStatus("No questions could be generated. Try a different topic or ingest more documents.", "error");
        return;
      }

      quizData = data;
      totalMCQ = data.mcq_questions.length;
      clearStatus();
      renderQuiz(data);

    } catch (err) {
      setStatus(`Request failed: ${err.message}`, "error");
    } finally {
      btn.disabled = false;
      btn.textContent = "Generate Quiz";
    }
  }

  function renderQuiz(data) {
    const out = document.getElementById("quizOutput");
    out.innerHTML = "";

    // MCQ section
    if (data.mcq_questions.length > 0) {
      out.innerHTML += `<div class="section-label">Multiple Choice (${data.mcq_questions.length} questions)</div>`;
      data.mcq_questions.forEach((q, i) => {
        out.appendChild(buildMCQCard(q, i));
      });
    }

    // Short answer section
    if (data.short_answer_questions.length > 0) {
      out.innerHTML += `<div class="section-label">Short Answer (${data.short_answer_questions.length} questions)</div>`;
      data.short_answer_questions.forEach((q, i) => {
        out.appendChild(buildSACard(q, i));
      });
    }

    // Score bar
    document.getElementById("scoreBar").style.display = "flex";
    updateScore();
  }

  function buildMCQCard(q, index) {
    const page = q.page ? ` · p.${q.page}` : "";
    const card = document.createElement("div");
    card.className = "q-card";
    card.id = `mcq-${index}`;

    const optionsHtml = q.options.map(opt => {
      const letter = opt.charAt(0);
      return `
        <div class="option" onclick="selectMCQ(${index}, '${letter}', '${q.answer}')"
             id="opt-${index}-${letter}">
          <div class="option-letter">${letter}</div>
          <span>${escapeHtml(opt.substring(3))}</span>
        </div>`;
    }).join("");

    card.innerHTML = `
      <div class="q-header">
        <div class="q-number">${index + 1}</div>
        <div>
          <div class="q-text">${escapeHtml(q.question)}</div>
          <div class="q-source">📄 ${escapeHtml(q.source)}${page}</div>
        </div>
      </div>
      <div class="options">${optionsHtml}</div>
      <div class="explanation" id="exp-${index}">
        💡 ${escapeHtml(q.explanation)}
      </div>`;

    return card;
  }

  function selectMCQ(index, selected, correct) {
    if (mcqAnswers[index] !== undefined) return; // already answered

    mcqAnswers[index] = selected;
    const isCorrect = selected === correct;
    mcqCorrect[index] = isCorrect;

    answeredMCQ++;
    if (isCorrect) correctMCQ++;

    // Colour all options
    ["A", "B", "C", "D"].forEach(letter => {
      const opt = document.getElementById(`opt-${index}-${letter}`);
      if (!opt) return;
      if (letter === correct) {
        opt.classList.add("correct");
      } else if (letter === selected && !isCorrect) {
        opt.classList.add("wrong");
      }
      opt.style.cursor = "default";
    });

    // Show explanation
    document.getElementById(`exp-${index}`).classList.add("show");
    updateScore();

    if (answeredMCQ === totalMCQ) checkAllAnswered();
  }

  function buildSACard(q, index) {
    const page = q.page ? ` · p.${q.page}` : "";
    const card = document.createElement("div");
    card.className = "q-card";

    const keyPoints = (q.key_points || [])
      .map(p => `<span class="key-point">${escapeHtml(p)}</span>`)
      .join("");

    card.innerHTML = `
      <div class="q-header">
        <div class="q-number" style="background:#8b5cf6">${index + 1}</div>
        <div>
          <div class="q-text">${escapeHtml(q.question)}</div>
          <div class="q-source">📄 ${escapeHtml(q.source)}${page}</div>
        </div>
      </div>
      <textarea class="sa-input" id="sa-input-${index}"
                placeholder="Type your answer here…"></textarea>
      <div class="btn-row">
        <button class="btn-sm btn-reveal" onclick="revealSA(${index})">Show Answer</button>
      </div>
      <div class="sa-reveal" id="sa-reveal-${index}">
        <strong style="color:#e2e8f0">Model Answer:</strong><br>
        ${escapeHtml(q.answer)}
        ${keyPoints ? `<div class="key-points" style="margin-top:0.5rem">
          <span style="font-size:0.72rem;color:#64748b">Key points: </span>${keyPoints}
        </div>` : ""}
      </div>`;

    return card;
  }

  function revealSA(index) {
    document.getElementById(`sa-reveal-${index}`).classList.add("show");
    saRevealed[index] = true;
    checkAllAnswered();
  }

  function updateScore() {
    const pct = totalMCQ > 0 ? Math.round((correctMCQ / totalMCQ) * 100) : 0;
    document.getElementById("scoreDisplay").textContent =
      `${correctMCQ} / ${totalMCQ}`;
    document.getElementById("answeredDisplay").textContent = answeredMCQ;
    document.getElementById("scoreFill").style.width = pct + "%";
  }

  function checkAllAnswered() {
    if (!quizData) return;
    const saTotal = quizData.short_answer_questions.length;
    const saAnswered = Object.keys(saRevealed).length;
    if (answeredMCQ >= totalMCQ && saAnswered >= saTotal) {
      showResults();
    }
  }

  function showResults() {
    const pct = totalMCQ > 0 ? Math.round((correctMCQ / totalMCQ) * 100) : 100;
    const panel = document.getElementById("resultsPanel");
    document.getElementById("finalScore").textContent = `${pct}%`;
    document.getElementById("finalSub").textContent =
      `${correctMCQ} of ${totalMCQ} MCQ correct · ${quizData.short_answer_questions.length} short answer reviewed`;
    panel.classList.add("show");
    panel.scrollIntoView({ behavior: "smooth" });
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text || "";
    return div.innerHTML;
  }

  document.getElementById("topicInput").addEventListener("keypress", e => {
    if (e.key === "Enter") generateQuiz();
  });
</script>
</body>
