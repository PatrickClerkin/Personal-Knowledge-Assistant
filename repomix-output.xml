<script>
/* ═══════════════════════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════════════════════ */
const viewMeta = {
  chat:       {title:'Chat',               sub:'Ask anything about your documents'},
  search:     {title:'Semantic Search',    sub:'Find relevant passages across your corpus'},
  upload:     {title:'Upload Documents',   sub:'Ingest files into the knowledge base'},
  study:      {title:'Study Mode',         sub:'AI-powered personalised learning paths'},
  quiz:       {title:'Quiz Mode',          sub:'Test your knowledge with grounded questions'},
  summarise:  {title:'Summarise',          sub:'AI-generated document and corpus summaries'},
  graph:      {title:'Knowledge Graph',    sub:'Entity co-occurrence across documents'},
  conflicts:  {title:'Conflict Detection', sub:'Surface contradictions between documents'},
  similarity: {title:'Document Similarity',sub:'Semantic similarity across your corpus'},
  dashboard:  {title:'Evaluation',         sub:'IR metrics — Precision, MRR, nDCG'},
  analytics:  {title:'Analytics',          sub:'Query history, confidence trends, usage stats'},
  notes:      {title:'Notes',              sub:'Annotate chunks with your own notes and tags'},
};

function switchView(view, el) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.view').forEach(v => { v.classList.remove('active'); v.style.display = 'none'; });
  const target = document.getElementById('view-' + view);
  target.style.display = 'flex';
  target.classList.add('active');
  if (view === 'graph') target.style.flexDirection = 'column';
  document.getElementById('topbar-title').textContent = viewMeta[view].title;
  document.getElementById('topbar-sub').textContent   = viewMeta[view].sub;
  if (view === 'summarise' || view === 'similarity' || view === 'notes') loadDocDropdowns();
  if (view === 'analytics') loadAnalytics();
  if (view === 'notes') loadNotes();
}

/* ═══════════════════════════════════════════════════════════
   STATS + DOC DROPDOWNS
═══════════════════════════════════════════════════════════ */
async function loadStats() {
  try { const d = await (await fetch('/api/info')).json(); document.getElementById('sb-chunks').textContent = d.total_chunks; document.getElementById('sb-docs').textContent = d.num_documents; } catch(e) {}
}
loadStats();

async function loadDocDropdowns() {
  try {
    const data = await (await fetch('/api/documents')).json();
    const docs = data.documents || [];
    ['sumDocSelect','simDocSelect','noteDocSelect'].forEach(id => {
      const sel = document.getElementById(id); if (!sel) return;
      const cur = sel.value;
      sel.innerHTML = '<option value="">— Select a document —</option>';
      docs.forEach(d => { const o = document.createElement('option'); o.value = d.doc_id; o.textContent = `${d.title} (${d.chunk_count} chunks)`; sel.appendChild(o); });
      if (cur) sel.value = cur;
    });
  } catch(e) {}
}

function esc(t) { const d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; }

/* ═══════════════════════════════════════════════════════════
   CHAT — STREAMING
═══════════════════════════════════════════════════════════ */
const chatMessages = document.getElementById('chatMessages');
const chatInput    = document.getElementById('chatInput');
const chatSendBtn  = document.getElementById('chatSendBtn');

function chatKeydown(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); } }

function appendMsg(role, html) {
  const wrap = document.createElement('div'); wrap.className = `chat-msg ${role}`;
  const bubble = document.createElement('div'); bubble.className = 'msg-bubble'; bubble.innerHTML = html;
  wrap.appendChild(bubble); chatMessages.appendChild(wrap); chatMessages.scrollTop = chatMessages.scrollHeight; return bubble;
}

async function sendChat() {
  const q = chatInput.value.trim(); if (!q) return;
  appendMsg('user', esc(q)); chatInput.value = ''; chatSendBtn.disabled = true;
  chatMessages.scrollTop = chatMessages.scrollHeight;

  // Typing indicator
  const tw = document.createElement('div'); tw.className = 'chat-msg assistant';
  tw.innerHTML = `<div class="msg-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  chatMessages.appendChild(tw); chatMessages.scrollTop = chatMessages.scrollHeight;

  let streamWrap = null, streamBubble = null, fullAnswer = '';

  try {
    const response = await fetch('/api/chat/stream', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({question: q}),
    });

    if (!response.ok) {
      const err = await response.json().catch(() => ({error: 'Unknown error'}));
      tw.remove();
      appendMsg('assistant', `<span style="color:var(--red)">${esc(err.error || 'Server error')}</span>`);
      return;
    }

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';

    while (true) {
      const {done, value} = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, {stream: true});
      const parts = buffer.split('\n\n');
      buffer = parts.pop(); // keep any incomplete chunk

      for (const part of parts) {
        if (!part.startsWith('data: ')) continue;
        let event;
        try { event = JSON.parse(part.slice(6)); } catch { continue; }

        if (event.type === 'token') {
          // First token — swap typing indicator for streaming bubble
          if (!streamBubble) {
            tw.remove();
            streamWrap = document.createElement('div'); streamWrap.className = 'chat-msg assistant';
            streamBubble = document.createElement('div'); streamBubble.className = 'msg-bubble stream-cursor';
            streamWrap.appendChild(streamBubble); chatMessages.appendChild(streamWrap);
          }
          fullAnswer += event.text;
          streamBubble.innerHTML = marked.parse(fullAnswer);
          chatMessages.scrollTop = chatMessages.scrollHeight;

        } else if (event.type === 'cache_hit') {
          tw.remove();
          let html = marked.parse(event.answer);
          html += buildMetaBar(event);
          if (event.grounding?.length) html += buildCitationChips(event.grounding);
          appendMsg('assistant', html);

        } else if (event.type === 'done') {
          if (streamBubble) {
            streamBubble.classList.remove('stream-cursor');
            // Swap to verified view if verdicts available, else keep markdown
            let html = '';
            if (event.verification?.verdicts?.length > 0) {
              html += renderVerifiedAnswer(event.verification.verdicts);
            } else {
              html += marked.parse(fullAnswer);
            }
            html += buildMetaBar(event);
            if (event.grounding?.length) html += buildCitationChips(event.grounding);
            streamBubble.innerHTML = html;
            chatMessages.scrollTop = chatMessages.scrollHeight;
          }
          // Update turn counter
          const tc = document.getElementById('chatTurnCount');
          if (tc) { const cur = parseInt(tc.textContent) || 0; updateTurnCount(cur + 1); }

        } else if (event.type === 'error') {
          if (tw.parentNode) tw.remove();
          if (streamWrap) streamWrap.remove();
          appendMsg('assistant', `<span style="color:var(--red)">${esc(event.message)}</span>`);
        }
      }
    }

  } catch(e) {
    if (tw.parentNode) tw.remove();
    if (streamWrap) streamWrap.remove();
    appendMsg('assistant', `<span style="color:var(--red)">Error: ${esc(e.message)}</span>`);
  } finally {
    chatSendBtn.disabled = false;
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
}

function renderVerifiedAnswer(verdicts) {
  const cls = {supported:'sent-supported',partial:'sent-partial',unverified:'sent-unverified'};
  const legend = `<div style="display:flex;gap:0.6rem;margin-bottom:0.6rem;font-size:0.7rem;flex-wrap:wrap"><span style="color:var(--green)">● Supported</span><span style="color:var(--amber)">● Partial</span><span style="color:var(--text-dim)">● Unverified</span></div>`;
  const sentences = verdicts.map(v => { const tip = v.best_source ? `${v.status} · ${v.best_source}${v.best_page?' p.'+v.best_page:''} · ${v.best_score.toFixed(3)}` : v.status; return `<span class="${cls[v.status]||'sent-unverified'}" title="${esc(tip)}">${esc(v.sentence)}</span>`; }).join(' ');
  return legend + `<p style="line-height:1.9">${sentences}</p>`;
}

function buildMetaBar(data) {
  if (data.confidence == null) return '';
  const pct = Math.round(data.confidence * 100);
  const col = data.confidence >= 0.4 ? 'var(--green)' : data.confidence >= 0.15 ? 'var(--amber)' : 'var(--red)';
  const lbl = data.confidence >= 0.4 ? 'strong' : data.confidence >= 0.15 ? 'partial' : 'weak';
  let badges = `<span class="badge badge-${lbl==='strong'?'green':lbl==='partial'?'amber':'red'}">${lbl} · ${pct}%</span>`;
  if (data.cache_hit) badges += `<span class="badge badge-blue">⚡ cached</span>`;
  if (data.retrieval_attempts > 1) badges += `<span class="badge badge-purple">↺ ${data.retrieval_attempts} attempts</span>`;
  if (data.verification) { const vs = Math.round(data.verification.overall_verification_score * 100); badges += `<span class="badge badge-${vs>=70?'green':vs>=40?'amber':'red'}">✓ ${vs}% verified</span>`; }
  return `<div class="answer-meta">${badges}<div class="confidence-track"><div class="confidence-fill" style="width:${pct}%;background:${col}"></div></div><span style="font-size:0.68rem;color:var(--text-dim)">grounding</span></div>`;
}

function buildCitationChips(grounding) {
  const chips = grounding.slice(0,4).map(g => { const cls = g.label==='strong'?'strong':g.label==='partial'?'partial':'weak'; const col = g.label==='strong'?'var(--green)':g.label==='partial'?'var(--amber)':'var(--red)'; const page = g.page?` p.${g.page}`:''; return `<div class="citation-chip ${cls}"><span style="font-size:0.72rem">📄</span><span>${esc(g.source)}${page}</span><span class="citation-score" style="color:${col}">${g.grounding_score.toFixed(3)}</span></div>`; }).join('');
  return `<div class="citation-row">${chips}</div>`;
}

