let confDistChart=null,queryDayChart=null;

async function loadAnalytics() {
  const status=document.getElementById('analyticsStatus');
  status.innerHTML=`<div class="status-msg status-info">Loading analytics…</div>`;
  try {
    const [aRes,hRes]=await Promise.all([fetch('/api/analytics'),fetch('/api/history?n=30')]);
    const [a,h]=await Promise.all([aRes.json(),hRes.json()]);
    if(a.error){status.innerHTML=`<div class="status-msg status-error">${esc(a.error)}</div>`;return;}
    status.innerHTML=''; renderAnalytics(a,h);
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
}

function renderAnalytics(a,h) {
  document.getElementById('an-total').textContent=a.total_queries;
  document.getElementById('an-cache').textContent=(a.cache_hit_rate*100).toFixed(1)+'%';
  document.getElementById('an-conf').textContent=(a.avg_confidence*100).toFixed(1)+'%';
  document.getElementById('an-tokens').textContent=a.total_tokens.toLocaleString();
  document.getElementById('analyticsMetrics').style.display='grid';
  document.getElementById('analyticsCharts').style.display='grid';
  const chartOpts={plugins:{legend:{display:false}},scales:{y:{ticks:{color:'#6b7f99'},grid:{color:'#1e2a3a'}},x:{ticks:{color:'#6b7f99'},grid:{display:false}}}};
  if(confDistChart) confDistChart.destroy();
  confDistChart=new Chart(document.getElementById('confDistChart'),{type:'bar',data:{labels:['Low (<15%)','Medium (15–40%)','High (>40%)'],datasets:[{data:[a.confidence_distribution.low,a.confidence_distribution.medium,a.confidence_distribution.high],backgroundColor:['#f06f6f','#f0a855','#3ecf8e'],borderRadius:6}]},options:chartOpts});
  if(queryDayChart) queryDayChart.destroy();
  const days=(a.queries_by_day||[]).slice(-14);
  queryDayChart=new Chart(document.getElementById('queryDayChart'),{type:'line',data:{labels:days.map(d=>d.date.slice(5)),datasets:[{data:days.map(d=>d.count),borderColor:'#4f9eff',backgroundColor:'rgba(79,158,255,0.08)',pointBackgroundColor:'#4f9eff',tension:0.3,fill:true}]},options:chartOpts});
  document.getElementById('analyticsSourcesCard').style.display='block';
  const maxC=a.top_sources.length>0?a.top_sources[0].count:1;
  document.getElementById('analyticsSourcesList').innerHTML=a.top_sources.length>0?a.top_sources.map(s=>{const pct=Math.round(s.count/maxC*100);return`<div style="display:flex;align-items:center;gap:0.75rem;padding:0.45rem 0;border-bottom:1px solid var(--border)"><div style="font-size:0.82rem;min-width:160px;color:var(--text-muted)">📄 ${esc(s.source)}</div><div style="flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden"><div style="height:100%;width:${pct}%;background:var(--blue);border-radius:2px;transition:width 0.4s"></div></div><div style="font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--blue);min-width:24px;text-align:right">${s.count}</div></div>`;}).join(''):`<div style="font-size:0.82rem;color:var(--text-dim)">No queries recorded yet.</div>`;
  document.getElementById('analyticsHistoryCard').style.display='block';
  document.getElementById('analyticsHistoryCount').textContent=`${h.total} total`;
  const records=h.records||[];
  document.getElementById('historyTableBody').innerHTML=records.length>0?records.map(r=>{const cCol=r.confidence>=0.4?'var(--green)':r.confidence>=0.15?'var(--amber)':'var(--red)';const ts=r.timestamp?new Date(r.timestamp).toLocaleTimeString('en-IE',{hour:'2-digit',minute:'2-digit'}):'—';const date=r.timestamp?new Date(r.timestamp).toLocaleDateString('en-IE',{month:'short',day:'numeric'}):'';return`<tr><td style="padding:0.5rem 0.75rem;font-size:0.82rem;max-width:280px"><div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(r.query.length>60?r.query.slice(0,60)+'…':r.query)}</div><div style="font-size:0.7rem;color:var(--text-dim);margin-top:2px;font-style:italic">${esc((r.answer_preview||'').slice(0,80))}…</div></td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.75rem;color:${cCol}">${(r.confidence*100).toFixed(0)}%</td><td style="padding:0.5rem 0.75rem">${r.cache_hit?`<span class="badge badge-blue">⚡</span>`:`<span style="color:var(--text-dim);font-size:0.75rem">—</span>`}</td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--text-muted)">${r.retrieval_attempts}</td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--text-muted)">${((r.input_tokens||0)+(r.output_tokens||0)).toLocaleString()}</td><td style="padding:0.5rem 0.75rem;font-size:0.72rem;color:var(--text-dim)">${date} ${ts}</td></tr>`;}).join(''):`<tr><td colspan="6" style="padding:1.5rem;text-align:center;color:var(--text-dim);font-size:0.82rem">No query history yet.</td></tr>`;
}

/* ═══════════════════════════════════════════════════════════
   NOTES
═══════════════════════════════════════════════════════════ */
let allNotes=[];

async function loadNotes() {
  const out=document.getElementById('notesOutput');
  out.innerHTML=`<div class="skeleton" style="height:80px;margin-bottom:0.6rem"></div>`.repeat(3);
  try {
    const data=await (await fetch('/api/annotations?limit=100')).json();
    allNotes=data.annotations||[]; document.getElementById('noteCount').textContent=`${data.total} total`;
    renderNotes(allNotes);
  } catch(e){out.innerHTML=`<div class="status-msg status-error">Error loading notes: ${esc(e.message)}</div>`;}
}

function filterNotes() {
  const q=document.getElementById('noteSearch').value.trim().toLowerCase(),tag=document.getElementById('noteTagFilter').value.trim().toLowerCase();
  let f=allNotes;
  if(q) f=f.filter(n=>(n.note+n.chunk_preview+n.source_title).toLowerCase().includes(q));
  if(tag) f=f.filter(n=>n.tags&&n.tags.some(t=>t.includes(tag)));
  renderNotes(f);
}

function renderNotes(notes) {
  const out=document.getElementById('notesOutput');
  if(!notes.length){out.innerHTML=`<div class="empty-state"><div class="icon">📝</div><div class="title">No notes yet</div><div class="desc">Add a note above to get started.</div></div>`;return;}
  out.innerHTML=notes.map(n=>{
    const tags=(n.tags||[]).map(t=>`<span class="note-tag">#${esc(t)}</span>`).join('');
    const ts=n.timestamp?new Date(n.timestamp).toLocaleString('en-IE',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}):'';
    return`<div class="note-card" id="note-${esc(n.annotation_id)}">
      <div class="note-card-header"><div style="flex:1"><div style="font-size:0.78rem;font-weight:600;color:var(--blue)">📄 ${esc(n.source_title)}${n.page_number?' · p.'+n.page_number:''}</div><div class="note-card-meta">Chunk: <span style="font-family:'DM Mono',monospace">${esc((n.chunk_id||'').slice(0,16))}…</span> · ${ts}</div></div><button class="delete-btn" onclick="deleteNote('${esc(n.annotation_id)}')" title="Delete">✕</button></div>
      <div class="note-card-text">${esc(n.note)}</div>
      ${n.chunk_preview?`<div class="note-card-preview">${esc(n.chunk_preview.slice(0,180))}${n.chunk_preview.length>180?'…':''}</div>`:''}
      ${tags?`<div class="note-tags">${tags}</div>`:''}
    </div>`;
  }).join('');
}

async function addNote() {
  const chunkId=document.getElementById('noteChunkId').value.trim(),docId=document.getElementById('noteDocSelect').value,note=document.getElementById('noteText').value.trim();
  const tags=document.getElementById('noteTags').value.split(',').map(t=>t.trim()).filter(Boolean),preview=document.getElementById('notePreview').value.trim(),status=document.getElementById('noteStatus');
  if(!chunkId){status.innerHTML=`<span style="color:var(--amber)">Enter a Chunk ID</span>`;return;}
  if(!docId){status.innerHTML=`<span style="color:var(--amber)">Select a document</span>`;return;}
  if(!note){status.innerHTML=`<span style="color:var(--amber)">Write a note first</span>`;return;}
  const sel=document.getElementById('noteDocSelect'),sourceTitle=sel.options[sel.selectedIndex]?.text.split(' (')[0]||docId;
  try {
    const data=await (await fetch('/api/annotations',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({chunk_id:chunkId,doc_id:docId,source_title:sourceTitle,note,chunk_preview:preview,tags})})).json();
    if(data.error){status.innerHTML=`<span style="color:var(--red)">${esc(data.error)}</span>`;return;}
    status.innerHTML=`<span style="color:var(--green)">✓ Note saved</span>`;
    ['noteChunkId','noteText','noteTags','notePreview'].forEach(id=>document.getElementById(id).value='');
    setTimeout(()=>status.innerHTML='',2500); loadNotes();
  } catch(e){status.innerHTML=`<span style="color:var(--red)">${esc(e.message)}</span>`;}
}

async function deleteNote(annotationId) {
  try { const data=await (await fetch(`/api/annotations/${annotationId}`,{method:'DELETE'})).json(); if(data.deleted) loadNotes(); } catch(e){}
}

/* ═══════════════════════════════════════════════════════════
   CONVERSATION PERSISTENCE
═══════════════════════════════════════════════════════════ */
async function loadConversationHistory() {
  try {
    const data = await (await fetch('/api/conversation')).json();
    const turns = data.turns || [];
    if (turns.length === 0) return;

    // Remove welcome message and render history
    const welcome = chatMessages.querySelector('.chat-msg.assistant');
    if (welcome) welcome.remove();

    turns.forEach(t => {
      appendMsg('user', esc(t.question));
      const bubble = appendMsg('assistant', marked.parse(t.answer));
      // Add a subtle restored indicator
      const tag = document.createElement('div');
      tag.style.cssText = 'font-size:0.68rem;color:var(--text-dim);margin-top:0.4rem;padding-top:0.4rem;border-top:1px solid var(--border)';
      const ts = t.timestamp ? new Date(t.timestamp).toLocaleString('en-IE', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '';
      tag.textContent = `↩ restored · ${ts}`;
      bubble.appendChild(tag);
    });

    updateTurnCount(turns.length);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  } catch(e) {
    // Silently fail — history just won't load
  }
}

function updateTurnCount(n) {
  const el = document.getElementById('chatTurnCount');
  if (el) el.textContent = n > 0 ? `${n} turn${n === 1 ? '' : 's'} in memory` : '';
}

async function clearConversation() {
  try {
    await fetch('/api/conversation/clear', {method: 'POST'});
    // Clear the chat UI
    chatMessages.innerHTML = `<div class="chat-msg assistant">
      <div class="msg-bubble">
        <p>👋 Welcome to your <strong>Personal Knowledge Assistant</strong>. I'm powered by a sophisticated RAG pipeline with hybrid search, HyDE retrieval, adaptive re-retrieval, and sentence-level fact verification.</p>
        <p style="margin-top:0.5rem">Ask me anything about your ingested documents.</p>
      </div>
    </div>`;
    updateTurnCount(0);
  } catch(e) {}
}

/* ═══════════════════════════════════════════════════════════
   INIT
═══════════════════════════════════════════════════════════ */
function updateTime(){const el=document.getElementById('tb-time');el.style.display='block';el.textContent=new Date().toLocaleTimeString('en-IE',{hour:'2-digit',minute:'2-digit'})}
updateTime(); setInterval(updateTime,30000);
loadConversationHistory();
</script>
