    #view-chat.active{display:flex}
    .chat-messages{flex:1;overflow-y:auto;padding:1.5rem;display:flex;flex-direction:column;gap:1rem}
    .chat-msg{display:flex;flex-direction:column;max-width:85%;animation:fadeSlideIn 0.2s ease}
    @keyframes fadeSlideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .chat-msg.user{align-self:flex-end;align-items:flex-end}
    .chat-msg.assistant{align-self:flex-start;align-items:flex-start;max-width:100%}
    .msg-bubble{padding:0.85rem 1.1rem;border-radius:12px;font-size:0.88rem;line-height:1.65}
    .chat-msg.user .msg-bubble{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border-radius:12px 12px 2px 12px}
    .chat-msg.assistant .msg-bubble{background:var(--surface);border:1px solid var(--border);border-radius:2px 12px 12px 12px;color:var(--text);width:100%}
    .msg-bubble p{margin:0.3rem 0}
    .msg-bubble ul,.msg-bubble ol{padding-left:1.4rem;margin:0.4rem 0}
    .msg-bubble li{margin:0.2rem 0}
    .msg-bubble strong{color:#e2eaf5}
    .msg-bubble h1,.msg-bubble h2,.msg-bubble h3{font-family:'Syne',sans-serif;font-size:0.95rem;color:var(--blue);margin:0.6rem 0 0.3rem}
    .msg-bubble code{background:var(--bg);color:var(--cyan);padding:0.1rem 0.4rem;border-radius:4px;font-family:'DM Mono',monospace;font-size:0.82rem}
    .msg-bubble pre{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.75rem;margin:0.5rem 0;overflow-x:auto}
    .msg-bubble pre code{background:none;padding:0}
    .answer-meta{display:flex;align-items:center;gap:0.4rem;margin-top:0.6rem;padding-top:0.6rem;border-top:1px solid var(--border);flex-wrap:wrap}
    .confidence-track{flex:1;min-width:60px;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
    .confidence-fill{height:100%;border-radius:2px;transition:width 0.5s ease}
    .citation-row{display:flex;gap:0.5rem;margin-top:0.75rem;flex-wrap:wrap}
    .citation-chip{display:flex;align-items:center;gap:0.4rem;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.35rem 0.65rem;font-size:0.75rem;color:var(--text-muted)}
    .citation-chip.strong{border-left:3px solid var(--green)}
    .citation-chip.partial{border-left:3px solid var(--amber)}
    .citation-chip.weak{border-left:3px solid var(--red);opacity:0.7}
    .citation-score{font-family:'DM Mono',monospace;font-size:0.7rem}
    .sent-supported{background:rgba(62,207,142,0.08);border-bottom:2px solid var(--green);padding:1px 2px;border-radius:2px;cursor:help}
    .sent-partial{background:rgba(240,168,85,0.08);border-bottom:2px solid var(--amber);padding:1px 2px;border-radius:2px;cursor:help}
    .sent-unverified{background:rgba(107,127,153,0.06);border-bottom:2px solid var(--text-dim);padding:1px 2px;border-radius:2px;cursor:help}
    .chat-input-bar{padding:1rem 1.5rem;background:var(--bg2);border-top:1px solid var(--border);display:flex;gap:0.75rem;align-items:flex-end}
    .chat-input-wrap{flex:1;position:relative}
    .chat-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.88rem;padding:0.75rem 1rem;outline:none;resize:none;min-height:48px;max-height:120px;transition:border-color 0.15s}
    .chat-input:focus{border-color:var(--blue)}
    .chat-input::placeholder{color:var(--text-dim)}
    .chat-send-btn{width:48px;height:48px;border-radius:10px;background:var(--blue);border:none;color:white;font-size:1.1rem;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .chat-send-btn:hover{background:#6aaeff;transform:translateY(-1px)}
    .chat-send-btn:disabled{background:var(--surface2);cursor:not-allowed;transform:none}
    .typing-dots{display:flex;gap:4px;align-items:center;padding:0.5rem 0}
    .typing-dots span{width:6px;height:6px;border-radius:50%;background:var(--text-dim);animation:bounce 1.2s infinite}
    .typing-dots span:nth-child(2){animation-delay:0.2s}
    .typing-dots span:nth-child(3){animation-delay:0.4s}
    @keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}

    /* streaming cursor blink */
    .stream-cursor::after{content:'▋';animation:blink 0.8s step-end infinite;color:var(--blue);font-size:0.85em}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

    .search-bar{display:flex;gap:0.75rem;margin-bottom:1.25rem}
    .result-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.25rem;margin-bottom:0.75rem;transition:border-color 0.15s;animation:fadeSlideIn 0.2s ease}
    .result-card:hover{border-color:var(--border2)}
    .result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem}
    .result-rank{font-family:'DM Mono',monospace;font-size:0.75rem;color:var(--text-dim);background:var(--surface2);padding:0.15rem 0.5rem;border-radius:4px}
    .result-source{font-size:0.78rem;color:var(--text-muted);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.4rem}
    .result-content{font-size:0.85rem;color:var(--text-muted);line-height:1.6}

    .upload-zone{border:2px dashed var(--border2);border-radius:16px;padding:3rem 2rem;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--surface);margin-bottom:1.5rem}
    .upload-zone:hover,.upload-zone.dragover{border-color:var(--blue);background:rgba(79,158,255,0.05)}
    .upload-icon{font-size:2.5rem;margin-bottom:0.75rem}
    .upload-text{font-size:0.9rem;color:var(--text-muted)}
    .upload-hint{font-size:0.78rem;color:var(--text-dim);margin-top:0.4rem}
    .upload-result{display:flex;align-items:center;gap:0.75rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.75rem 1rem;margin-bottom:0.5rem;font-size:0.85rem;animation:fadeSlideIn 0.2s ease}

    .study-section-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:0.75rem;overflow:hidden;transition:border-color 0.15s}
    .study-section-card:hover{border-color:var(--border2)}
    .study-section-header{display:flex;align-items:center;gap:0.75rem;padding:1rem 1.25rem;cursor:pointer}
    .section-num{width:28px;height:28px;border-radius:50%;background:var(--blue);color:white;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;flex-shrink:0}
    .section-concept{flex:1;font-weight:500;font-size:0.9rem;text-transform:capitalize}
    .section-body{display:none;padding:0 1.25rem 1.25rem;border-top:1px solid var(--border)}
    .study-section-card.open .section-body{display:block}
    .section-summary{font-size:0.85rem;color:var(--text-muted);line-height:1.7;margin:0.75rem 0}
    .term-list{display:flex;flex-wrap:wrap;gap:0.35rem;margin-top:0.5rem}
    .term-tag{background:var(--blue-dim);color:var(--blue);border:1px solid rgba(79,158,255,0.2);border-radius:4px;padding:0.15rem 0.5rem;font-size:0.72rem}
    .study-progress{height:3px;background:var(--border);border-radius:2px;margin-bottom:1.25rem;overflow:hidden}
    .study-progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:2px;transition:width 0.4s ease}
    .mark-done-btn{display:inline-flex;align-items:center;gap:0.35rem;background:var(--green-dim);color:var(--green);border:1px solid rgba(62,207,142,0.2);border-radius:var(--radius-sm);padding:0.35rem 0.9rem;font-size:0.78rem;cursor:pointer;margin-top:0.75rem;transition:all 0.15s;font-family:'DM Sans',sans-serif}
    .mark-done-btn:hover{background:rgba(62,207,142,0.2)}
    .mark-done-btn.done{opacity:0.6}

    .quiz-scorebar{display:flex;align-items:center;gap:1rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.25rem;margin-bottom:1.25rem}
    .score-display{font-family:'Syne',sans-serif;font-weight:800;font-size:1.5rem;color:var(--blue)}
    .score-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
    .score-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--green));border-radius:3px;transition:width 0.4s ease}
    .q-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;margin-bottom:0.75rem;animation:fadeSlideIn 0.2s ease}
    .q-header{display:flex;gap:0.75rem;margin-bottom:1rem}
    .q-num{width:26px;height:26px;border-radius:50%;background:var(--blue);color:white;display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:700;flex-shrink:0;margin-top:2px}
    .q-text{font-size:0.9rem;line-height:1.6}
    .q-source{font-size:0.72rem;color:var(--text-dim);margin-top:0.25rem}
    .option{display:flex;align-items:center;gap:0.75rem;padding:0.65rem 0.9rem;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;font-size:0.86rem;transition:all 0.15s;margin-bottom:0.4rem}
    .option:hover{border-color:var(--blue);background:rgba(79,158,255,0.05)}
    .option.correct{border-color:var(--green);background:var(--green-dim);color:var(--green)}
    .option.wrong{border-color:var(--red);background:var(--red-dim);color:var(--red)}
    .opt-letter{width:22px;height:22px;border-radius:50%;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0}
    .explanation{margin-top:0.75rem;padding:0.6rem 0.9rem;background:var(--bg);border-left:3px solid var(--blue-dim);border-radius:0 var(--radius-sm) var(--radius-sm) 0;font-size:0.8rem;color:var(--text-muted);display:none}
    .explanation.show{display:block}
    .sa-input{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.85rem;padding:0.65rem 0.9rem;resize:vertical;min-height:80px;outline:none;margin-bottom:0.5rem}
    .sa-input:focus{border-color:var(--blue)}
    .sa-model{background:var(--bg);border-left:3px solid var(--purple-dim);padding:0.65rem 0.9rem;border-radius:0 var(--radius-sm) var(--radius-sm) 0;font-size:0.8rem;color:var(--text-muted);display:none}
    .sa-model.show{display:block}

    #graph-canvas{flex:1;position:relative;overflow:hidden}
    #graph-canvas svg{width:100%;height:100%}
    .graph-toolbar{display:flex;align-items:center;gap:0.75rem;padding:0.75rem 1.5rem;background:var(--bg2);border-bottom:1px solid var(--border)}
    .graph-tooltip{position:absolute;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:0.6rem 0.9rem;font-size:0.78rem;pointer-events:none;display:none;max-width:200px;z-index:10;box-shadow:0 8px 24px rgba(0,0,0,0.4)}

    .conflict-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:0.75rem;overflow:hidden}
    .conflict-card.high{border-left:4px solid var(--red)}
    .conflict-card.medium{border-left:4px solid var(--amber)}
    .conflict-card.low{border-left:4px solid var(--blue)}
    .conflict-header{display:flex;align-items:flex-start;justify-content:space-between;gap:0.75rem;padding:1rem 1.25rem;cursor:pointer}
    .conflict-desc{font-size:0.88rem;font-weight:500;margin-bottom:0.3rem}
    .conflict-sources{font-size:0.75rem;color:var(--text-dim)}
    .conflict-body{display:none;padding:0 1.25rem 1.25rem;border-top:1px solid var(--border)}
    .conflict-card.open .conflict-body{display:block}
    .excerpts-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:1rem}
    .excerpt-panel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.9rem}
    .excerpt-label{font-size:0.68rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.4rem;font-weight:600}
    .excerpt-source{font-size:0.78rem;font-weight:500;color:var(--text-muted);margin-bottom:0.4rem}
    .excerpt-text{font-size:0.8rem;color:var(--text-muted);line-height:1.6}
    .claim-box{margin-top:0.6rem;padding:0.5rem 0.75rem;border-radius:4px;font-size:0.78rem;font-style:italic}
    .claim-a{background:rgba(240,111,111,0.08);border-left:2px solid var(--red);color:#fca5a5}
    .claim-b{background:rgba(240,168,85,0.08);border-left:2px solid var(--amber);color:var(--amber)}

    .metric-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.25rem}
    .metric-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem}
    .metric-label{font-size:0.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em}
    .metric-value{font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;margin:0.2rem 0}
    .metric-value.blue{color:var(--blue)} .metric-value.green{color:var(--green)} .metric-value.amber{color:var(--amber)} .metric-value.purple{color:var(--purple)}
    .charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.25rem}
    .chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem}
    .chart-card h3{font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:1rem}

    .summary-executive{background:linear-gradient(135deg,rgba(79,158,255,0.06),rgba(34,211,238,0.04));border:1px solid rgba(79,158,255,0.2);border-radius:var(--radius);padding:1.25rem;margin-bottom:1rem}
    .summary-executive-title{font-family:'Syne',sans-serif;font-weight:700;font-size:0.82rem;color:var(--blue);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem}
    .summary-executive-text{font-size:0.88rem;color:var(--text-muted);line-height:1.75}
    .key-points-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.6rem;margin-bottom:1rem}
    .key-point-card{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:var(--radius-sm);padding:0.75rem 1rem;font-size:0.82rem;color:var(--text-muted);line-height:1.55}
    .summary-section-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:0.6rem;overflow:hidden}
    .summary-section-header{display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1.1rem;cursor:pointer}
    .summary-section-header:hover{background:var(--surface2)}
    .summary-section-pill{width:24px;height:24px;border-radius:50%;background:var(--purple);color:white;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0}
    .summary-section-body{display:none;padding:0 1.1rem 1rem;border-top:1px solid var(--border);font-size:0.83rem;color:var(--text-muted);line-height:1.7}
    .summary-section-card.open .summary-section-body{display:block}

    .sim-result-card{display:flex;align-items:center;gap:0.9rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.85rem 1rem;margin-bottom:0.5rem;animation:fadeSlideIn 0.2s ease}
    .sim-result-card:hover{border-color:var(--border2)}
    .sim-bar-wrap{height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:0.3rem}
    .sim-bar-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:2px;transition:width 0.5s ease}
    .sim-score{font-family:'DM Mono',monospace;font-size:0.78rem;min-width:42px;text-align:right;font-weight:500}

    .analytics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.25rem}
    .history-table{width:100%;border-collapse:collapse;font-size:0.82rem}
    .history-table th{text-align:left;padding:0.5rem 0.75rem;color:var(--text-muted);font-weight:500;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em;border-bottom:1px solid var(--border)}
    .history-table td{padding:0.5rem 0.75rem;border-bottom:1px solid var(--border);vertical-align:top}

    .note-form{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem;margin-bottom:1.25rem}
    .note-form-title{font-family:'Syne',sans-serif;font-weight:700;font-size:0.82rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.9rem}
    .note-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;margin-bottom:0.6rem}
    .form-label{font-size:0.72rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.3rem}
    .note-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.1rem;margin-bottom:0.65rem;animation:fadeSlideIn 0.2s ease}
    .note-card:hover{border-color:var(--border2)}
    .note-card-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.5rem}
    .note-card-meta{font-size:0.7rem;color:var(--text-dim);margin-top:2px}
    .note-card-text{font-size:0.85rem;color:var(--text);line-height:1.6;margin-bottom:0.5rem}
    .note-card-preview{font-size:0.78rem;color:var(--text-dim);background:var(--bg2);border-left:2px solid var(--border2);padding:0.4rem 0.7rem;border-radius:0 4px 4px 0;font-style:italic;margin-bottom:0.5rem;line-height:1.55}
    .note-tags{display:flex;flex-wrap:wrap;gap:0.3rem}
    .note-tag{background:var(--purple-dim);color:var(--purple);border:1px solid rgba(167,139,250,0.2);border-radius:4px;padding:0.1rem 0.45rem;font-size:0.7rem}
    .delete-btn{background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:0.85rem;padding:0.2rem 0.4rem;border-radius:4px;transition:all 0.15s;flex-shrink:0}
    .delete-btn:hover{color:var(--red);background:var(--red-dim)}

    ::-webkit-scrollbar{width:4px;height:4px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
    ::-webkit-scrollbar-thumb:hover{background:var(--text-dim)}

    .empty-state{text-align:center;padding:3rem 2rem;color:var(--text-dim)}
    .empty-state .icon{font-size:2.5rem;margin-bottom:0.75rem}
    .empty-state .title{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;color:var(--text-muted);margin-bottom:0.4rem}
    .empty-state .desc{font-size:0.82rem}
    .skeleton{background:linear-gradient(90deg,var(--surface) 25%,var(--surface2) 50%,var(--surface) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:var(--radius-sm)}
    @keyframes shimmer{from{background-position:200% 0}to{background-position:-200% 0}}

    .flex{display:flex} .gap-sm{gap:0.5rem} .gap-md{gap:0.75rem}
    .mt-sm{margin-top:0.5rem} .mt-md{margin-top:0.75rem}
    .hidden{display:none!important}
    #fileInput{display:none}

    @media(max-width:900px){
      .sidebar{width:180px} :root{--sidebar-w:180px}
      .metric-grid,.analytics-grid{grid-template-columns:repeat(2,1fr)}
      .charts-grid{grid-template-columns:1fr}
      .excerpts-grid,.note-form-grid,.key-points-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-text">PKA</div>
    <div class="logo-sub">Personal Knowledge Assistant</div>
  </div>
  <div class="sidebar-stats">
    <div class="stat-pill"><div class="val" id="sb-chunks">—</div><div class="lbl">Chunks</div></div>
    <div class="stat-pill"><div class="val" id="sb-docs">—</div><div class="lbl">Docs</div></div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Workspace</div>
    <div class="nav-item active" data-view="chat" onclick="switchView('chat',this)"><span class="nav-icon">💬</span><span>Chat</span></div>
    <div class="nav-item" data-view="search" onclick="switchView('search',this)"><span class="nav-icon">🔍</span><span>Search</span></div>
    <div class="nav-item" data-view="upload" onclick="switchView('upload',this)"><span class="nav-icon">📤</span><span>Upload</span></div>
    <div class="nav-section-label">Learning</div>
    <div class="nav-item" data-view="study" onclick="switchView('study',this)"><span class="nav-icon">📚</span><span>Study Mode</span></div>
    <div class="nav-item" data-view="quiz" onclick="switchView('quiz',this)"><span class="nav-icon">🧠</span><span>Quiz</span></div>
    <div class="nav-item" data-view="summarise" onclick="switchView('summarise',this)"><span class="nav-icon">📋</span><span>Summarise</span></div>
    <div class="nav-section-label">Intelligence</div>
    <div class="nav-item" data-view="graph" onclick="switchView('graph',this)"><span class="nav-icon">🕸</span><span>Knowledge Graph</span></div>
    <div class="nav-item" data-view="conflicts" onclick="switchView('conflicts',this)"><span class="nav-icon">⚡</span><span>Conflicts</span></div>
    <div class="nav-item" data-view="similarity" onclick="switchView('similarity',this)"><span class="nav-icon">🔗</span><span>Similarity</span></div>
