  </style>
</head>
<body>

  <h1>📊 Evaluation Dashboard</h1>
  <p class="subtitle">IR metrics for the Personal Knowledge Assistant retrieval pipeline</p>

  <div class="controls">
    <input type="text" id="queryPath" value="data/eval/test_queries.json"
           placeholder="Path to test_queries.json" />
    <button id="runBtn" onclick="runEvaluation()">▶ Run Evaluation</button>
  </div>

  <div id="status"></div>

  <div class="stat-grid" id="statGrid" style="display:none">
    <div class="stat-card">
      <div class="label">Queries Evaluated</div>
      <div class="value" id="numQueries" style="color:#e2e8f0">—</div>
    </div>
    <div class="stat-card">
      <div class="label">Mean Precision@5</div>
      <div class="value" id="p5">—</div>
    </div>
    <div class="stat-card">
      <div class="label">Mean MRR</div>
      <div class="value" id="mrr">—</div>
    </div>
    <div class="stat-card">
      <div class="label">Mean nDCG@5</div>
      <div class="value" id="ndcg">—</div>
    </div>
  </div>

  <div class="charts-grid" id="chartsGrid" style="display:none">
    <div class="chart-card">
      <h2>METRIC AVERAGES</h2>
      <canvas id="barChart"></canvas>
    </div>
    <div class="chart-card">
      <h2>PER-QUERY nDCG@5</h2>
      <canvas id="lineChart"></canvas>
    </div>
  </div>

  <div class="table-card" id="tableCard" style="display:none">
    <h2>PER-QUERY BREAKDOWN</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Query</th>
          <th>P@5</th>
          <th>MRR</th>
          <th>nDCG@5</th>
          <th>Grade</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>

<script>
  let barChart = null;
  let lineChart = null;

  function colorClass(v) {
    if (v >= 0.6) return "good";
    if (v >= 0.3) return "mid";
    return "poor";
  }

  function setStatus(msg, type) {
    const el = document.getElementById("status");
    el.textContent = msg;
    el.className = type;
  }

  function grade(p5, mrr, ndcg) {
    const avg = (p5 + mrr + ndcg) / 3;
    return colorClass(avg);
  }

  async function runEvaluation() {
    const btn = document.getElementById("runBtn");
    const path = document.getElementById("queryPath").value.trim();
    btn.disabled = true;
    btn.textContent = "Running…";
    setStatus("Running evaluation — this may take a few seconds…", "info");

    // Hide results sections while running
    ["statGrid", "chartsGrid", "tableCard"].forEach(id => {
      document.getElementById(id).style.display = "none";
    });

    try {
      const res = await fetch(`/api/evaluation/run?path=${encodeURIComponent(path)}`);
      const data = await res.json();

      if (!res.ok) {
        setStatus(`Error: ${data.error}`, "error");
        return;
      }

      renderStats(data);
      renderCharts(data);
      renderTable(data);

      document.getElementById("statGrid").style.display = "grid";
      document.getElementById("chartsGrid").style.display = "grid";
      document.getElementById("tableCard").style.display = "block";
      setStatus(`✓ Evaluated ${data.num_queries} queries successfully.`, "info");

    } catch (err) {
      setStatus(`Request failed: ${err.message}`, "error");
    } finally {
      btn.disabled = false;
      btn.textContent = "▶ Run Evaluation";
    }
  }

  function renderStats(data) {
    document.getElementById("numQueries").textContent = data.num_queries;
    for (const [id, val] of [
      ["p5", data.mean_precision_at_5],
      ["mrr", data.mean_mrr],
      ["ndcg", data.mean_ndcg_at_5],
    ]) {
      const el = document.getElementById(id);
      el.textContent = val.toFixed(3);
      el.className = `value ${colorClass(val)}`;
    }
  }

  function renderCharts(data) {
    const chartDefaults = {
      color: "#94a3b8",
      borderColor: "#2d3748",
    };

    // Bar chart — aggregate metrics
    if (barChart) barChart.destroy();
    barChart = new Chart(document.getElementById("barChart"), {
      type: "bar",
      data: {
        labels: ["Precision@5", "MRR", "nDCG@5"],
        datasets: [{
          label: "Score",
          data: [data.mean_precision_at_5, data.mean_mrr, data.mean_ndcg_at_5],
          backgroundColor: ["#3b82f6", "#8b5cf6", "#10b981"],
          borderRadius: 6,
        }],
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          y: {
            min: 0, max: 1,
            ticks: { color: "#94a3b8" },
            grid: { color: "#1a1f2e" },
          },
          x: { ticks: { color: "#94a3b8" }, grid: { display: false } },
        },
      },
    });

    // Line chart — per-query nDCG
    const labels = data.query_results.map((r, i) => `Q${i + 1}`);
    const ndcgVals = data.query_results.map(r => r.ndcg_at_5);

    if (lineChart) lineChart.destroy();
    lineChart = new Chart(document.getElementById("lineChart"), {
      type: "line",
      data: {
        labels,
        datasets: [{
          label: "nDCG@5",
          data: ndcgVals,
          borderColor: "#10b981",
          backgroundColor: "rgba(16,185,129,0.1)",
          pointBackgroundColor: "#10b981",
          tension: 0.3,
          fill: true,
        }],
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          y: {
            min: 0, max: 1,
            ticks: { color: "#94a3b8" },
            grid: { color: "#1a1f2e" },
          },
          x: { ticks: { color: "#94a3b8" }, grid: { display: false } },
        },
      },
    });
  }

  function renderTable(data) {
    const tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";
    data.query_results.forEach((r, i) => {
      const g = grade(r.precision_at_5, r.mrr, r.ndcg_at_5);
      const label = g === "good" ? "Strong" : g === "mid" ? "Partial" : "Weak";
      tbody.innerHTML += `
        <tr>
          <td>${i + 1}</td>
          <td title="${r.query}">${r.query.length > 55 ? r.query.slice(0, 55) + "…" : r.query}</td>
          <td>${r.precision_at_5.toFixed(3)}</td>
          <td>${r.mrr.toFixed(3)}</td>
          <td>${r.ndcg_at_5.toFixed(3)}</td>
          <td><span class="badge ${g}">${label}</span></td>
        </tr>`;
    });
  }
</script>
</body>
</html>
