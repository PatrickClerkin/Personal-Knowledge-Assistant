def _make_chunk(
    chunk_id: str = "chunk_1",
    doc_id: str = "test_doc",
    content: str = "Test content about neural networks.",
    source: str = "test.pdf",
    page: int = 1,
) -> Chunk:
    return Chunk(
        chunk_id=chunk_id,
        doc_id=doc_id,
        content=content,
        source_doc_title=source,
        page_number=page,
        metadata={},
    )


def _make_result(chunk: Chunk = None, score: float = 0.85, rank: int = 1) -> SearchResult:
    return SearchResult(
        chunk=chunk or _make_chunk(),
        score=score,
        rank=rank,
    )


