let studyCompleted = new Set();

async function generateStudy() {
  const topic = document.getElementById('studyTopic').value.trim(); if (!topic) return;
  const btn = document.getElementById('studyBtn'), status = document.getElementById('studyStatus'), out = document.getElementById('studyOutput');
  btn.disabled = true; btn.textContent = 'Generating…'; status.innerHTML = `<div class="status-msg status-info">Building study path for "${esc(topic)}"…</div>`; out.innerHTML = ''; studyCompleted.clear();
  try {
    const data = await (await fetch('/api/study/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({topic})})).json();
    if (data.error) { status.innerHTML = `<div class="status-msg status-error">${esc(data.error)}</div>`; return; }
    status.innerHTML = ''; renderStudy(data, out);
  } catch(e) { status.innerHTML = `<div class="status-msg status-error">${esc(e.message)}</div>`; }
  finally { btn.disabled = false; btn.textContent = 'Generate Path'; }
}

function renderStudy(data, out) {
  out.innerHTML = `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem"><div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem">${esc(data.topic)}</div><div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px">~${data.estimated_minutes} min · ${data.total_sources} source(s) · ${data.sections.length} sections</div></div></div><div class="study-progress"><div class="study-progress-fill" id="studyProgressFill" style="width:0%"></div></div><div id="studySections"></div>`;
  const container = document.getElementById('studySections');
  data.sections.forEach((s, i) => {
    const terms = (s.key_terms||[]).map(t=>`<span class="term-tag">${esc(t)}</span>`).join('');
    const sources = (s.sources||[]).map(src=>`<span style="font-size:0.75rem;color:var(--text-muted);background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:0.15rem 0.5rem">📄 ${esc(src)}</span>`).join('');
    const card = document.createElement('div'); card.className = 'study-section-card'; card.dataset.idx = i;
    card.innerHTML = `<div class="study-section-header" onclick="toggleStudy(${i})"><div class="section-num">${s.order}</div><div class="section-concept">${esc(s.concept)}</div><span style="color:var(--text-dim);font-size:0.8rem">▼</span></div><div class="section-body"><p class="section-summary">${esc(s.summary)}</p>${terms?`<div style="margin-top:0.6rem"><div style="font-size:0.68rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.35rem">Key Terms</div><div class="term-list">${terms}</div></div>`:''}${sources?`<div style="margin-top:0.6rem"><div style="font-size:0.68rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.35rem">Sources</div><div style="display:flex;flex-wrap:wrap;gap:0.35rem">${sources}</div></div>`:''}<button class="mark-done-btn" id="study-done-${i}" onclick="markStudyDone(${i},event)">✓ Mark as studied</button></div>`;
    container.appendChild(card);
  });
  toggleStudy(0);
}

function toggleStudy(i) { document.querySelector(`.study-section-card[data-idx="${i}"]`)?.classList.toggle('open'); }
function markStudyDone(i, e) {
  e.stopPropagation(); const btn = document.getElementById(`study-done-${i}`);
  if (studyCompleted.has(i)) { studyCompleted.delete(i); btn.textContent='✓ Mark as studied'; btn.classList.remove('done'); }
  else { studyCompleted.add(i); btn.textContent='✓ Studied'; btn.classList.add('done'); }
  const total = document.querySelectorAll('.study-section-card').length; const fill = document.getElementById('studyProgressFill');
  if (fill) fill.style.width = (total>0?studyCompleted.size/total*100:0)+'%';
}

