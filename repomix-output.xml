<body>
<div class="container">
  <h1>📚 Study Mode</h1>
  <p class="subtitle">Generate a personalised learning path from your documents</p>

  <div class="input-row">
    <input type="text" id="topicInput" placeholder="What do you want to study? e.g. neural networks, logistic regression…"/>
    <button id="generateBtn" onclick="generatePath()">Generate Path</button>
  </div>

  <div id="status"></div>
  <div id="output"></div>
</div>

<script>
  let completedSections = new Set();

  function setStatus(msg, type) {
    const el = document.getElementById("status");
    el.textContent = msg;
    el.className = type;
  }

  function clearStatus() {
    const el = document.getElementById("status");
    el.className = "";
    el.textContent = "";
  }

  async function generatePath() {
    const topic = document.getElementById("topicInput").value.trim();
    if (!topic) return;

    const btn = document.getElementById("generateBtn");
    btn.disabled = true;
    btn.textContent = "Generating…";
    setStatus(`Building study path for "${topic}" — this may take 20–40 seconds…`, "info");
    document.getElementById("output").innerHTML = "";
    completedSections.clear();

    try {
      const res = await fetch("/api/study/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ topic }),
      });
      const data = await res.json();

      if (!res.ok || data.error) {
        setStatus(`Error: ${data.error || "Unknown error"}`, "error");
        return;
      }

      clearStatus();
      renderPath(data);
    } catch (err) {
      setStatus(`Request failed: ${err.message}`, "error");
    } finally {
      btn.disabled = false;
      btn.textContent = "Generate Path";
    }
  }

  function renderPath(data) {
    const output = document.getElementById("output");

    // Path header
    output.innerHTML = `
      <div class="path-header">
        <div class="path-title">📖 ${escapeHtml(data.topic)}</div>
        <div class="path-meta">
          <span class="meta-pill">⏱ ~${data.estimated_minutes} min</span>
          <span class="meta-pill">📄 ${data.total_sources} source(s)</span>
          <span class="meta-pill">📝 ${data.sections.length} sections</span>
        </div>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill" style="width:0%"></div>
      </div>
      <div id="sections"></div>`;

    const container = document.getElementById("sections");

    data.sections.forEach(section => {
      const termPills = (section.key_terms || [])
        .map(t => `<span class="term-pill">${escapeHtml(t)}</span>`)
        .join("");

      const sourceRefs = (section.sources || [])
        .map(s => `<span class="source-ref">📄 ${escapeHtml(s)}</span>`)
        .join("");

      const previews = (section.chunk_previews || []).slice(0, 2)
        .map(p => `<div class="chunk-preview">${escapeHtml(p)}</div>`)
        .join("");

      const card = document.createElement("div");
      card.className = "section-card";
      card.dataset.order = section.order;
      card.innerHTML = `
        <div class="section-header" onclick="toggleSection(this)">
          <div class="section-number">${section.order}</div>
          <div class="section-concept">${escapeHtml(section.concept)}</div>
          <span class="section-toggle">▼</span>
        </div>
        <div class="section-body">
          <p class="section-summary">${escapeHtml(section.summary)}</p>
          <div class="section-row">
            <div class="key-terms-block">
              <div class="block-label">Key Terms</div>
              ${termPills || '<span style="color:#4b5563;font-size:0.8rem">None extracted</span>'}
            </div>
            <div class="sources-block">
              <div class="block-label">Sources</div>
              ${sourceRefs || '<span style="color:#4b5563;font-size:0.8rem">No sources</span>'}
            </div>
          </div>
          ${previews ? `<div class="previews-label">Excerpts from your documents</div>${previews}` : ""}
          <button class="complete-btn" onclick="markComplete(${section.order}, this)">
            ✓ Mark as studied
          </button>
        </div>`;

      container.appendChild(card);
    });

    // Auto-open first section
    const first = container.querySelector(".section-card");
    if (first) first.classList.add("open");
  }

  function toggleSection(header) {
    const card = header.closest(".section-card");
    card.classList.toggle("open");
  }

  function markComplete(order, btn) {
    const card = document.querySelector(`.section-card[data-order="${order}"]`);
    if (completedSections.has(order)) {
      completedSections.delete(order);
      card.classList.remove("completed");
      btn.textContent = "✓ Mark as studied";
      btn.classList.remove("done");
    } else {
      completedSections.add(order);
      card.classList.add("completed");
      btn.textContent = "✓ Studied";
      btn.classList.add("done");
    }
    updateProgress();
  }

  function updateProgress() {
    const total = document.querySelectorAll(".section-card").length;
    const done = completedSections.size;
    const pct = total > 0 ? Math.round((done / total) * 100) : 0;
    document.getElementById("progressFill").style.width = pct + "%";
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text || "";
    return div.innerHTML;
  }

  // Allow Enter key to trigger generation
  document.getElementById("topicInput").addEventListener("keypress", e => {
    if (e.key === "Enter") generatePath();
  });
</script>
</body>
</html>
