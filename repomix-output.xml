function renderSummary(data,out,compact) {
  if(data.executive_summary){const exec=document.createElement('div');exec.className='summary-executive';exec.innerHTML=`<div class="summary-executive-title">Executive Summary</div><div class="summary-executive-text">${esc(data.executive_summary)}</div>`;out.appendChild(exec);}
  if(data.key_points?.length){const grid=document.createElement('div');grid.className='key-points-grid';data.key_points.forEach(p=>{const c=document.createElement('div');c.className='key-point-card';c.textContent=p;grid.appendChild(c);});out.appendChild(grid);}
  if(!compact&&data.sections?.length){
    const hdr=document.createElement('div');hdr.style.cssText='font-size:0.72rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em;margin:0.75rem 0 0.5rem;font-weight:600';hdr.textContent='Section Breakdown';out.appendChild(hdr);
    data.sections.forEach((s,i)=>{const card=document.createElement('div');card.className='summary-section-card';card.innerHTML=`<div class="summary-section-header" onclick="this.parentElement.classList.toggle('open')"><div class="summary-section-pill">${i+1}</div><div style="flex:1;font-size:0.86rem;font-weight:500">${esc(s.title||s.concept||'Section '+(i+1))}</div><span style="color:var(--text-dim);font-size:0.8rem">▼</span></div><div class="summary-section-body">${esc(s.content||s.summary||'')}</div>`;out.appendChild(card);});
  }
}

/* ═══════════════════════════════════════════════════════════
   GRAPH
═══════════════════════════════════════════════════════════ */
let graphSvg=null,graphSimulation=null,graphZoom=null;
const nodeColours={PERSON:'#60a5fa',ORG:'#3ecf8e',GPE:'#f0a855',LOC:'#a78bfa',PRODUCT:'#f06f6f',EVENT:'#22d3ee',NORP:'#e879f9',default:'#6b7f99'};
function nodeCol(l){return nodeColours[l]||nodeColours.default}
function nodeR(deg,cnt){return Math.max(5,Math.min(22,5+Math.sqrt(deg)*2+Math.log1p(cnt)))}
function resetGraphZoom(){if(graphSvg&&graphZoom)graphSvg.transition().duration(400).call(graphZoom.transform,d3.zoomIdentity)}

async function loadGraph(rebuild=false) {
  document.getElementById('graphEmpty').style.display='none'; document.getElementById('graphStats').textContent='Loading…'; d3.select('#graph-canvas svg').remove();
  try {
    const data=await (await fetch(rebuild?'/api/graph?rebuild=true':'/api/graph')).json();
    if(!data.nodes?.length){document.getElementById('graphEmpty').style.display='';document.getElementById('graphStats').textContent='No entities found — ingest documents first.';return;}
    document.getElementById('graphStats').textContent=`${data.num_nodes} entities · ${data.num_edges} connections`; renderGraph(data);
  } catch(e){document.getElementById('graphStats').textContent=`Error: ${e.message}`;}
}

function renderGraph(data) {
  const container=document.getElementById('graph-canvas'),W=container.clientWidth,H=container.clientHeight,tooltip=document.getElementById('graphTooltip');
  graphSvg=d3.select('#graph-canvas').append('svg'); const g=graphSvg.append('g');
  graphZoom=d3.zoom().scaleExtent([0.1,4]).on('zoom',e=>g.attr('transform',e.transform)); graphSvg.call(graphZoom);
  const edgeScale=d3.scaleLinear().domain([1,d3.max(data.links,l=>l.weight)||1]).range([0.5,3.5]);
  const link=g.append('g').selectAll('line').data(data.links).join('line').attr('stroke','#1e2a3a').attr('stroke-width',d=>edgeScale(d.weight)).attr('stroke-opacity',0.6);
  const node=g.append('g').selectAll('g').data(data.nodes).join('g').call(d3.drag().on('start',(ev,d)=>{if(!ev.active)graphSimulation.alphaTarget(0.3).restart();d.fx=d.x;d.fy=d.y}).on('drag',(ev,d)=>{d.fx=ev.x;d.fy=ev.y}).on('end',(ev,d)=>{if(!ev.active)graphSimulation.alphaTarget(0);d.fx=null;d.fy=null}));
  node.append('circle').attr('r',d=>nodeR(d.degree,d.count)).attr('fill',d=>nodeCol(d.label)).attr('fill-opacity',0.85).attr('stroke',d=>nodeCol(d.label)).attr('stroke-opacity',0.3).attr('stroke-width',2)
    .on('mouseover',(ev,d)=>{tooltip.style.display='block';tooltip.innerHTML=`<strong style="color:var(--text)">${esc(d.id)}</strong><br><span style="color:var(--text-muted);font-size:0.72rem">Type: ${d.label} · ${d.count} chunk(s) · ${d.degree} connection(s)</span>`})
    .on('mousemove',ev=>{tooltip.style.left=(ev.offsetX+14)+'px';tooltip.style.top=(ev.offsetY-10)+'px'})
    .on('mouseout',()=>{tooltip.style.display='none'});
  node.append('text').text(d=>d.id.length>12?d.id.slice(0,10)+'…':d.id).attr('dy',d=>nodeR(d.degree,d.count)+10).attr('text-anchor','middle').attr('fill','#6b7f99').attr('font-size','9px').attr('pointer-events','none');
  graphSimulation=d3.forceSimulation(data.nodes).force('link',d3.forceLink(data.links).id(d=>d.id).distance(d=>80+25/(d.weight||1))).force('charge',d3.forceManyBody().strength(-120)).force('center',d3.forceCenter(W/2,H/2)).force('collision',d3.forceCollide().radius(d=>nodeR(d.degree,d.count)+4)).on('tick',()=>{link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y).attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);node.attr('transform',d=>`translate(${d.x},${d.y})`)});
}

/* ═══════════════════════════════════════════════════════════
   CONFLICTS
═══════════════════════════════════════════════════════════ */
async function detectConflicts() {
  const topic=document.getElementById('conflictTopic').value.trim(); if(!topic) return;
  const btn=document.getElementById('conflictBtn'),status=document.getElementById('conflictStatus'),out=document.getElementById('conflictOutput');
  btn.disabled=true; btn.textContent='Analysing…'; status.innerHTML=`<div class="status-msg status-info">Scanning documents for conflicts on "${esc(topic)}"…</div>`; out.innerHTML='';
  try {
    const data=await (await fetch('/api/conflicts/detect',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({topic})})).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    status.innerHTML=''; renderConflicts(data,out);
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
  finally{btn.disabled=false;btn.textContent='Detect Conflicts';}
}

function renderConflicts(data,out) {
  const summaryBadges=data.total_conflicts===0?`<span class="badge badge-green">✓ No conflicts</span>`:`<span class="badge badge-red">${data.high_count} High</span><span class="badge badge-amber">${data.medium_count} Medium</span><span class="badge badge-blue">${data.low_count} Low</span>`;
  out.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem"><div><div style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem">${esc(data.topic)}</div><div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px">${data.documents_analysed} docs · ${data.pairs_compared} pairs compared</div></div><div style="display:flex;gap:0.4rem;flex-wrap:wrap">${summaryBadges}</div></div>`;
  if(!data.conflicts.length){out.innerHTML+=`<div class="empty-state"><div class="icon">✅</div><div class="title">No conflicts detected</div><div class="desc">Documents on this topic appear consistent.</div></div>`;return;}
  data.conflicts.forEach((c,i)=>{
    const pA=c.page_a?` p.${c.page_a}`:'',pB=c.page_b?` p.${c.page_b}`:'',sevCol=c.severity==='high'?'red':c.severity==='medium'?'amber':'blue';
    const card=document.createElement('div');card.className=`conflict-card ${c.severity}`;card.id=`cc-${i}`;
    card.innerHTML=`<div class="conflict-header" onclick="document.getElementById('cc-${i}').classList.toggle('open')"><div style="flex:1"><div class="conflict-desc">${esc(c.description)}</div><div class="conflict-sources">${esc(c.source_a)}${pA} <span style="color:var(--text-dim)">vs</span> ${esc(c.source_b)}${pB}</div></div><div style="display:flex;gap:0.4rem;align-items:center;flex-shrink:0"><span class="badge badge-${sevCol}">${c.severity}</span><span class="badge" style="background:var(--surface2);color:var(--text-muted)">${c.conflict_type}</span><span style="color:var(--text-dim);font-size:0.8rem">▼</span></div></div><div class="conflict-body"><div class="excerpts-grid"><div class="excerpt-panel"><div class="excerpt-label">Document A</div><div class="excerpt-source">📄 ${esc(c.source_a)}${pA}</div><div class="excerpt-text">${esc((c.excerpt_a||'').substring(0,350))}${(c.excerpt_a||'').length>350?'…':''}</div>${c.claim_a?`<div class="claim-box claim-a">"${esc(c.claim_a)}"</div>`:''}</div><div class="excerpt-panel"><div class="excerpt-label">Document B</div><div class="excerpt-source">📄 ${esc(c.source_b)}${pB}</div><div class="excerpt-text">${esc((c.excerpt_b||'').substring(0,350))}${(c.excerpt_b||'').length>350?'…':''}</div>${c.claim_b?`<div class="claim-box claim-b">"${esc(c.claim_b)}"</div>`:''}</div></div></div>`;
    out.appendChild(card);
  });
  document.getElementById('cc-0')?.classList.add('open');
}

/* ═══════════════════════════════════════════════════════════
   SIMILARITY
═══════════════════════════════════════════════════════════ */
async function findSimilar() {
  const docId=document.getElementById('simDocSelect').value;
  if(!docId){document.getElementById('simStatus').innerHTML=`<div class="status-msg status-error">Please select a document first.</div>`;return;}
  const status=document.getElementById('simStatus'),out=document.getElementById('simOutput');
  document.getElementById('simMatrix').innerHTML=''; status.innerHTML=`<div class="status-msg status-info">Finding similar documents…</div>`; out.innerHTML='';
  try {
    const data=await (await fetch(`/api/similarity/${docId}`)).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    if(!data.similar?.length){status.innerHTML=`<div class="status-msg status-info">No similar documents found.</div>`;return;}
    status.innerHTML='';
    out.innerHTML=`<div style="font-family:'Syne',sans-serif;font-weight:700;font-size:0.82rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem">Most Similar to: ${esc(data.query_title||docId)}</div>`;
    data.similar.forEach(r=>{const pct=Math.round(r.similarity*100);const col=r.similarity>=0.7?'var(--green)':r.similarity>=0.4?'var(--amber)':'var(--red)';const card=document.createElement('div');card.className='sim-result-card';card.innerHTML=`<div style="flex:1"><div style="font-weight:500;font-size:0.88rem;margin-bottom:0.2rem">${esc(r.title)}</div><div style="font-size:0.72rem;color:var(--text-dim)">${r.chunk_count} chunks · ${esc(r.doc_id)}</div><div class="sim-bar-wrap" style="margin-top:0.4rem"><div class="sim-bar-fill" style="width:${pct}%"></div></div></div><div class="sim-score" style="color:${col}">${r.similarity.toFixed(3)}</div>`;out.appendChild(card);});
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
}

async function loadSimilarityMatrix() {
  const status=document.getElementById('simStatus'),out=document.getElementById('simOutput'),matDiv=document.getElementById('simMatrix');
  out.innerHTML=''; status.innerHTML=`<div class="status-msg status-info">Computing similarity matrix…</div>`;
  try {
    const data=await (await fetch('/api/similarity/matrix')).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    if(!data.documents?.length){status.innerHTML=`<div class="status-msg status-error">No documents found.</div>`;return;}
    status.innerHTML=''; renderHeatmap(data,matDiv);
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
}

function renderHeatmap(data,container) {
  const n=data.documents.length,cellSize=Math.min(52,Math.floor(540/n));
  const margin={top:110,left:110,right:20,bottom:20},W=cellSize*n+margin.left+margin.right,H=cellSize*n+margin.top+margin.bottom;
  const labels=data.documents.map(d=>d.title.length>12?d.title.slice(0,10)+'…':d.title);
  container.innerHTML=`<div class="card" style="overflow-x:auto"><div class="card-title">Pairwise Similarity Matrix</div><svg id="heatmapSvg" width="${W}" height="${H}" style="display:block"></svg></div>`;
  const svg=d3.select('#heatmapSvg'),g=svg.append('g').attr('transform',`translate(${margin.left},${margin.top})`);
  for(let i=0;i<n;i++) for(let j=0;j<n;j++){
    const val=data.matrix[i][j],col=i===j?'rgba(79,158,255,0.25)':val>=0.7?'#3ecf8e':val>=0.4?'#f0a855':val>=0.2?'#1a3a6e':'#0d1421';
    g.append('rect').attr('x',j*cellSize).attr('y',i*cellSize).attr('width',cellSize-2).attr('height',cellSize-2).attr('rx',3).attr('fill',col).append('title').text(`${data.documents[i].title} × ${data.documents[j].title}: ${val.toFixed(3)}`);
    if(cellSize>=28) g.append('text').attr('x',j*cellSize+cellSize/2-1).attr('y',i*cellSize+cellSize/2+4).attr('text-anchor','middle').attr('fill',val>0.4||i===j?'#fff':'#6b7f99').attr('font-size','9px').attr('pointer-events','none').text(val.toFixed(2));
  }
  labels.forEach((lbl,i)=>g.append('text').attr('x',-6).attr('y',i*cellSize+cellSize/2+4).attr('text-anchor','end').attr('fill','#6b7f99').attr('font-size','10px').text(lbl));
  labels.forEach((lbl,j)=>g.append('text').attr('x',j*cellSize+cellSize/2).attr('y',-8).attr('text-anchor','start').attr('fill','#6b7f99').attr('font-size','10px').attr('transform',`rotate(-45,${j*cellSize+cellSize/2},-8)`).text(lbl));
}

/* ═══════════════════════════════════════════════════════════
   EVALUATION DASHBOARD
═══════════════════════════════════════════════════════════ */
let barChart=null,lineChart=null;

async function runEvaluation() {
  const btn=document.getElementById('evalBtn'),status=document.getElementById('evalStatus');
  btn.disabled=true; btn.textContent='Running…'; status.innerHTML=`<div class="status-msg status-info">Running evaluation…</div>`;
  document.getElementById('metricGrid').style.display='none'; document.getElementById('chartsGrid').style.display='none'; document.getElementById('evalTableCard').style.display='none';
  try {
    const data=await (await fetch('/api/evaluation/run')).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    status.innerHTML=''; renderEval(data);
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
  finally{btn.disabled=false;btn.textContent='▶ Run Evaluation';}
}

function metricColour(v){return v>=0.6?'green':v>=0.3?'amber':'red'}
function renderEval(data) {
  document.getElementById('m-queries').textContent=data.num_queries;
  ['p5','mrr','ndcg'].forEach((k,i)=>{const vals=[data.mean_precision_at_5,data.mean_mrr,data.mean_ndcg_at_5];document.getElementById(`m-${k}`).textContent=vals[i].toFixed(3);document.getElementById(`m-${k}`).className=`metric-value ${metricColour(vals[i])}`});
  document.getElementById('metricGrid').style.display='grid'; document.getElementById('chartsGrid').style.display='grid'; document.getElementById('evalTableCard').style.display='block';
  const chartOpts={plugins:{legend:{display:false}},scales:{y:{min:0,max:1,ticks:{color:'#6b7f99'},grid:{color:'#1e2a3a'}},x:{ticks:{color:'#6b7f99'},grid:{display:false}}}};
  if(barChart) barChart.destroy();
  barChart=new Chart(document.getElementById('barChart'),{type:'bar',data:{labels:['Precision@5','MRR','nDCG@5'],datasets:[{data:[data.mean_precision_at_5,data.mean_mrr,data.mean_ndcg_at_5],backgroundColor:['#4f9eff','#3ecf8e','#a78bfa'],borderRadius:6}]},options:chartOpts});
  if(lineChart) lineChart.destroy();
  lineChart=new Chart(document.getElementById('lineChart'),{type:'line',data:{labels:data.query_results.map((_,i)=>`Q${i+1}`),datasets:[{data:data.query_results.map(r=>r.ndcg_at_5),borderColor:'#3ecf8e',backgroundColor:'rgba(62,207,142,0.08)',pointBackgroundColor:'#3ecf8e',tension:0.3,fill:true}]},options:chartOpts});
  const col=v=>v>=0.6?'var(--green)':v>=0.3?'var(--amber)':'var(--red)';
  document.getElementById('evalTableBody').innerHTML=data.query_results.map((r,i)=>`<tr style="border-bottom:1px solid var(--border)"><td style="padding:0.5rem 0.75rem;color:var(--text-dim);font-family:'DM Mono',monospace;font-size:0.78rem">${i+1}</td><td style="padding:0.5rem 0.75rem;font-size:0.82rem">${esc(r.query.length>55?r.query.slice(0,55)+'…':r.query)}</td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:${col(r.precision_at_5)}">${r.precision_at_5.toFixed(3)}</td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:${col(r.mrr)}">${r.mrr.toFixed(3)}</td><td style="padding:0.5rem 0.75rem;font-family:'DM Mono',monospace;font-size:0.78rem;color:${col(r.ndcg_at_5)}">${r.ndcg_at_5.toFixed(3)}</td></tr>`).join('');
}

