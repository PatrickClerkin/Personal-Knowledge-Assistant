async function summariseAll() {
  const status=document.getElementById('sumStatus'),out=document.getElementById('sumOutput');
  status.innerHTML=`<div class="status-msg status-info">Generating corpus-wide summary…</div>`; out.innerHTML='';
  try {
    const data=await (await fetch('/api/summarise/all')).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    status.innerHTML='';
    if(data.summaries){
      out.innerHTML=`<div style="font-family:'Syne',sans-serif;font-weight:700;font-size:0.82rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem">Corpus Summary — ${data.summaries.length} documents</div>`;
      data.summaries.forEach(s=>{const wrap=document.createElement('div');wrap.innerHTML=`<div style="font-size:0.75rem;font-weight:600;color:var(--blue);margin:1rem 0 0.4rem">📄 ${esc(s.title||s.doc_id)}</div>`;out.appendChild(wrap);renderSummary(s,out,true);});
    } else { renderSummary(data,out,false); }
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
