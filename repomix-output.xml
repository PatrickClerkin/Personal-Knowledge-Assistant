═══════════════════════════════════════════════════════════ */
async function doSearch() {
  const q = document.getElementById('searchInput').value.trim(); if (!q) return;
  const out = document.getElementById('searchResults');
  out.innerHTML = `<div class="skeleton" style="height:80px;margin-bottom:0.75rem"></div>`.repeat(3);
  try {
    const data = await (await fetch('/api/search',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q,top_k:5})})).json();
    if (!data.results?.length) { out.innerHTML = `<div class="empty-state"><div class="icon">🔍</div><div class="title">No results</div><div class="desc">Try a different query or ingest more documents.</div></div>`; return; }
    out.innerHTML = data.results.map(r => { const sc = r.score>0.5?'var(--green)':r.score>0.3?'var(--amber)':'var(--red)'; const page = r.page?` · Page ${r.page}`:''; const preview = r.content.length>350?r.content.substring(0,350)+'…':r.content; return `<div class="result-card"><div class="result-header"><div style="display:flex;align-items:center;gap:0.5rem"><span class="result-rank">#${r.rank}</span><span style="font-size:0.78rem;font-weight:500;color:var(--text)">${esc(r.source)}</span></div><span style="font-family:'DM Mono',monospace;font-size:0.75rem;color:${sc};background:${sc}18;padding:0.15rem 0.5rem;border-radius:4px">${r.score.toFixed(3)}</span></div><div class="result-source">📄 ${esc(r.source)}${page}</div><div class="result-content">${esc(preview)}</div></div>`; }).join('');
  } catch(e) { out.innerHTML = `<div class="status-msg status-error">Error: ${esc(e.message)}</div>`; }
}

