function handleDrop(e) { e.preventDefault(); document.getElementById('uploadZone').classList.remove('dragover'); handleFiles(e.dataTransfer.files); }

async function handleFiles(files) {
  const out = document.getElementById('uploadResults');
  for (const file of files) {
    const row = document.createElement('div'); row.className = 'upload-result';
    row.innerHTML = `<span>⏳</span><span style="flex:1">${esc(file.name)}</span><span style="color:var(--text-dim);font-size:0.78rem">Uploading…</span>`;
    out.prepend(row);
    const form = new FormData(); form.append('file', file);
    try {
      const d = await (await fetch('/api/ingest',{method:'POST',body:form})).json();
      if (d.error) row.innerHTML = `<span style="color:var(--red)">✗</span><span style="flex:1">${esc(file.name)}</span><span style="color:var(--red);font-size:0.78rem">${esc(d.error)}</span>`;
      else { row.innerHTML = `<span style="color:var(--green)">✓</span><span style="flex:1">${esc(file.name)}</span><span style="color:var(--green);font-size:0.78rem">${d.chunks_created} chunks</span>`; loadStats(); loadDocDropdowns(); }
    } catch(e) { row.innerHTML = `<span style="color:var(--red)">✗</span><span style="flex:1">${esc(file.name)}</span><span style="color:var(--red);font-size:0.78rem">${esc(e.message)}</span>`; }
  }
}

