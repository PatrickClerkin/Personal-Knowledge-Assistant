        if summary is None:
            return jsonify({
                "error": f"No chunks found for document: {doc_id}"
            }), 404
        return jsonify(summary.to_dict())
    except Exception as e:
        logger.error("Summarisation error: %s", e)
        return jsonify({"error": str(e)}), 500
</file>

