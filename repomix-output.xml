let quizData=null,mcqAnswers={},mcqCorrect={},saRevealed={},totalMCQ=0,correctMCQ=0,answeredMCQ=0;

async function generateQuiz() {
  const topic = document.getElementById('quizTopic').value.trim(); if (!topic) return;
  const btn=document.getElementById('quizBtn'),status=document.getElementById('quizStatus'),out=document.getElementById('quizOutput');
  btn.disabled=true; btn.textContent='Generating…'; status.innerHTML=`<div class="status-msg status-info">Generating quiz on "${esc(topic)}"…</div>`; out.innerHTML='';
  document.getElementById('quizScorebar').classList.add('hidden');
  mcqAnswers={}; mcqCorrect={}; saRevealed={}; totalMCQ=0; correctMCQ=0; answeredMCQ=0;
  try {
    const data=await (await fetch('/api/quiz/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({topic})})).json();
    if(data.error){status.innerHTML=`<div class="status-msg status-error">${esc(data.error)}</div>`;return;}
    if(data.total_questions===0){status.innerHTML=`<div class="status-msg status-error">No questions generated. Try a different topic.</div>`;return;}
    quizData=data; totalMCQ=data.mcq_questions.length; status.innerHTML=''; document.getElementById('quizScorebar').classList.remove('hidden'); renderQuiz(data,out); updateQuizScore();
  } catch(e){status.innerHTML=`<div class="status-msg status-error">${esc(e.message)}</div>`;}
  finally{btn.disabled=false;btn.textContent='Generate Quiz';}
}

function renderQuiz(data,out) {
  if(data.mcq_questions.length>0){out.innerHTML+=`<div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.75rem">Multiple Choice · ${data.mcq_questions.length} questions</div>`;data.mcq_questions.forEach((q,i)=>out.appendChild(buildMCQCard(q,i)));}
  if(data.short_answer_questions.length>0){out.innerHTML+=`<div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;margin:1rem 0 0.75rem">Short Answer · ${data.short_answer_questions.length} questions</div>`;data.short_answer_questions.forEach((q,i)=>out.appendChild(buildSACard(q,i)));}
}

function buildMCQCard(q,index) {
  const card=document.createElement('div'); card.className='q-card'; card.id=`mcq-${index}`;
  const opts=q.options.map(opt=>{const letter=opt.charAt(0);return`<div class="option" id="opt-${index}-${letter}" onclick="selectMCQ(${index},'${letter}','${q.answer}')"><div class="opt-letter">${letter}</div><span>${esc(opt.substring(3))}</span></div>`;}).join('');
  card.innerHTML=`<div class="q-header"><div class="q-num">${index+1}</div><div><div class="q-text">${esc(q.question)}</div><div class="q-source">📄 ${esc(q.source)}${q.page?` · p.${q.page}`:''}</div></div></div><div class="options">${opts}</div><div class="explanation" id="exp-${index}">💡 ${esc(q.explanation)}</div>`;
  return card;
}

function selectMCQ(index,selected,correct) {
  if(mcqAnswers[index]!==undefined) return;
  mcqAnswers[index]=selected; const isCorrect=selected===correct; mcqCorrect[index]=isCorrect; answeredMCQ++; if(isCorrect) correctMCQ++;
  ['A','B','C','D'].forEach(l=>{const opt=document.getElementById(`opt-${index}-${l}`);if(!opt)return;if(l===correct)opt.classList.add('correct');else if(l===selected&&!isCorrect)opt.classList.add('wrong');opt.style.cursor='default';});
  document.getElementById(`exp-${index}`).classList.add('show'); updateQuizScore();
}

function buildSACard(q,index) {
  const card=document.createElement('div'); card.className='q-card';
  const kps=(q.key_points||[]).map(p=>`<span class="term-tag">${esc(p)}</span>`).join('');
  card.innerHTML=`<div class="q-header"><div class="q-num" style="background:var(--purple)">${index+1}</div><div><div class="q-text">${esc(q.question)}</div><div class="q-source">📄 ${esc(q.source)}${q.page?` · p.${q.page}`:''}</div></div></div><textarea class="sa-input" placeholder="Type your answer…"></textarea><div style="display:flex;gap:0.5rem;margin-top:0.4rem"><button class="btn btn-ghost" style="font-size:0.78rem;padding:0.35rem 0.9rem" onclick="revealSA(${index},this)">Show Answer</button></div><div class="sa-model" id="sa-${index}"><strong style="color:var(--text);display:block;margin-bottom:0.4rem">Model Answer:</strong>${esc(q.answer)}${kps?`<div class="term-list" style="margin-top:0.5rem">${kps}</div>`:''}</div>`;
  return card;
}

function revealSA(index,btn){document.getElementById(`sa-${index}`).classList.add('show');btn.disabled=true;}
function updateQuizScore(){const pct=totalMCQ>0?Math.round(correctMCQ/totalMCQ*100):0;document.getElementById('quizScoreDisplay').textContent=`${correctMCQ} / ${totalMCQ}`;document.getElementById('quizAnsweredDisplay').textContent=answeredMCQ;document.getElementById('quizScoreFill').style.width=pct+'%';}

